# Copy this file to `.env` and fill in real values.
#
# .env is loaded automatically by scripts/config.py at import time
# (provided python-dotenv is installed).

# -----------------------------------------------------------------------
# Paths (optional - defaults to ./data and ./logs relative to project root)
# -----------------------------------------------------------------------
# DATA_DIR=/absolute/path/to/data
# LOG_DIR=/absolute/path/to/logs

# -----------------------------------------------------------------------
# Weather API
# -----------------------------------------------------------------------
# Get a free key at https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=

# Default station: Central Park (KNYC). Override here if you want a
# different reference site.
# WEATHER_LAT=40.7794
# WEATHER_LON=-73.9692
# WEATHER_STATION_ID=KNYC

# -----------------------------------------------------------------------
# Kafka (optional in Phase 1)
# -----------------------------------------------------------------------
# Leave empty until Stage 2 (Kafka cluster) is up. When set, fetch_weather.py
# additionally publishes each observation to KAFKA_WEATHER_TOPIC.
# KAFKA_BROKERS=localhost:9092,localhost:9093,localhost:9094
# KAFKA_WEATHER_TOPIC=weather-events
